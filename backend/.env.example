# Copy to .env (and load it yourself, e.g. with python-dotenv or your host's env
# var settings) — app.py reads these via os.environ, they are NOT auto-loaded
# from a .env file out of the box.

# Secret used to sign JWTs. MUST be changed for any real deployment.
JWT_SECRET_KEY=change-this-in-production

# Optional: use MySQL instead of the default local SQLite file.
# DATABASE_URL=mysql+pymysql://user:password@host:3306/student_performance

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173
